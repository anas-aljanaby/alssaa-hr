# Remote dev (recommended if you skip local Supabase/Docker):
# Use your hosted project URL + anon key from Dashboard → Settings → API.
# Run the Vite app only (e.g. npm run dev). Edge functions run on Supabase when deployed
# to this project — do not run `supabase functions serve` unless you want local functions
# (that path expects Docker for the full local stack).

VITE_SUPABASE_URL=https://your-project-id.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# Used by edge functions (set via: supabase secrets set DEMO_RESET_SECRET=...)
# DEMO_RESET_SECRET=your-secret-here
